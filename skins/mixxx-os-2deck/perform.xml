<Template>
  <WidgetGroup>
    <ObjectName>PerformDeck</ObjectName>
    <Layout>vertical</Layout>
    <Size>0me,0me</Size>
    <Children>

      <!-- ═══ HOT CUE ═══ -->
      <WidgetGroup>
        <ObjectName>PerformSectionHeader</ObjectName>
        <Layout>horizontal</Layout>
        <Size>0me,14f</Size>
        <Children>
          <Label>
            <ObjectName>PerformSectionTitle</ObjectName>
            <Text>HOT CUE</Text>
          </Label>
        </Children>
      </WidgetGroup>

      <!-- Activate pads A B C D -->
      <WidgetGroup>
        <ObjectName>HotCuePads</ObjectName>
        <Layout>horizontal</Layout>
        <Size>0me,48f</Size>
        <Children>
          <PushButton>
            <ObjectName>HotCuePad1</ObjectName>
            <Size>0me,48f</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>A</Text></State>
            <State><Number>1</Number><Text>A</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],hotcue_1_activate</ConfigKey>
              <ConnectValueFromWidget>true</ConnectValueFromWidget>
              <ConnectValueToWidget>false</ConnectValueToWidget>
            </Connection>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],hotcue_1_enabled</ConfigKey>
              <ConnectValueFromWidget>false</ConnectValueFromWidget>
              <ConnectValueToWidget>true</ConnectValueToWidget>
            </Connection>
          </PushButton>
          <PushButton>
            <ObjectName>HotCuePad2</ObjectName>
            <Size>0me,48f</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>B</Text></State>
            <State><Number>1</Number><Text>B</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],hotcue_2_activate</ConfigKey>
              <ConnectValueFromWidget>true</ConnectValueFromWidget>
              <ConnectValueToWidget>false</ConnectValueToWidget>
            </Connection>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],hotcue_2_enabled</ConfigKey>
              <ConnectValueFromWidget>false</ConnectValueFromWidget>
              <ConnectValueToWidget>true</ConnectValueToWidget>
            </Connection>
          </PushButton>
          <PushButton>
            <ObjectName>HotCuePad3</ObjectName>
            <Size>0me,48f</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>C</Text></State>
            <State><Number>1</Number><Text>C</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],hotcue_3_activate</ConfigKey>
              <ConnectValueFromWidget>true</ConnectValueFromWidget>
              <ConnectValueToWidget>false</ConnectValueToWidget>
            </Connection>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],hotcue_3_enabled</ConfigKey>
              <ConnectValueFromWidget>false</ConnectValueFromWidget>
              <ConnectValueToWidget>true</ConnectValueToWidget>
            </Connection>
          </PushButton>
          <PushButton>
            <ObjectName>HotCuePad4</ObjectName>
            <Size>0me,48f</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>D</Text></State>
            <State><Number>1</Number><Text>D</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],hotcue_4_activate</ConfigKey>
              <ConnectValueFromWidget>true</ConnectValueFromWidget>
              <ConnectValueToWidget>false</ConnectValueToWidget>
            </Connection>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],hotcue_4_enabled</ConfigKey>
              <ConnectValueFromWidget>false</ConnectValueFromWidget>
              <ConnectValueToWidget>true</ConnectValueToWidget>
            </Connection>
          </PushButton>
        </Children>
      </WidgetGroup>

      <!-- Clear pads ✕A ✕B ✕C ✕D -->
      <WidgetGroup>
        <ObjectName>HotCueClearPads</ObjectName>
        <Layout>horizontal</Layout>
        <Size>0me,18f</Size>
        <Children>
          <PushButton>
            <ObjectName>HotCueClear1</ObjectName>
            <Size>0me,18f</Size>
            <NumberStates>1</NumberStates>
            <State><Number>0</Number><Text>&#x2715;A</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],hotcue_1_clear</ConfigKey>
              <ConnectValueFromWidget>true</ConnectValueFromWidget>
              <ConnectValueToWidget>false</ConnectValueToWidget>
            </Connection>
          </PushButton>
          <PushButton>
            <ObjectName>HotCueClear2</ObjectName>
            <Size>0me,18f</Size>
            <NumberStates>1</NumberStates>
            <State><Number>0</Number><Text>&#x2715;B</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],hotcue_2_clear</ConfigKey>
              <ConnectValueFromWidget>true</ConnectValueFromWidget>
              <ConnectValueToWidget>false</ConnectValueToWidget>
            </Connection>
          </PushButton>
          <PushButton>
            <ObjectName>HotCueClear3</ObjectName>
            <Size>0me,18f</Size>
            <NumberStates>1</NumberStates>
            <State><Number>0</Number><Text>&#x2715;C</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],hotcue_3_clear</ConfigKey>
              <ConnectValueFromWidget>true</ConnectValueFromWidget>
              <ConnectValueToWidget>false</ConnectValueToWidget>
            </Connection>
          </PushButton>
          <PushButton>
            <ObjectName>HotCueClear4</ObjectName>
            <Size>0me,18f</Size>
            <NumberStates>1</NumberStates>
            <State><Number>0</Number><Text>&#x2715;D</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],hotcue_4_clear</ConfigKey>
              <ConnectValueFromWidget>true</ConnectValueFromWidget>
              <ConnectValueToWidget>false</ConnectValueToWidget>
            </Connection>
          </PushButton>
        </Children>
      </WidgetGroup>

      <!-- ═══ BEAT LOOP ═══ -->
      <!-- Spacer for visual separation from HOT CUE section -->
      <WidgetGroup>
        <ObjectName>PerformSectionSpacer</ObjectName>
        <Layout>horizontal</Layout>
        <Size>0me,8f</Size>
        <Children/>
      </WidgetGroup>
      <WidgetGroup>
        <ObjectName>PerformSectionHeader</ObjectName>
        <Layout>horizontal</Layout>
        <Size>0me,14f</Size>
        <Children>
          <Label>
            <ObjectName>PerformSectionTitle</ObjectName>
            <Text>BEAT LOOP</Text>
          </Label>
        </Children>
      </WidgetGroup>

      <!-- Loop size pads: 1/2, 1, 2, 4, 8, 16 -->
      <WidgetGroup>
        <ObjectName>BeatLoopPads</ObjectName>
        <Layout>horizontal</Layout>
        <Size>0me,48f</Size>
        <Children>
          <PushButton>
            <ObjectName>BeatLoopPad</ObjectName>
            <Size>0me,48f</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>1/2</Text></State>
            <State><Number>1</Number><Text>1/2</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],beatloop_0.5_activate</ConfigKey>
            </Connection>
          </PushButton>
          <PushButton>
            <ObjectName>BeatLoopPad</ObjectName>
            <Size>0me,48f</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>1</Text></State>
            <State><Number>1</Number><Text>1</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],beatloop_1_activate</ConfigKey>
            </Connection>
          </PushButton>
          <PushButton>
            <ObjectName>BeatLoopPad</ObjectName>
            <Size>0me,48f</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>2</Text></State>
            <State><Number>1</Number><Text>2</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],beatloop_2_activate</ConfigKey>
            </Connection>
          </PushButton>
          <PushButton>
            <ObjectName>BeatLoopPad</ObjectName>
            <Size>0me,48f</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>4</Text></State>
            <State><Number>1</Number><Text>4</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],beatloop_4_activate</ConfigKey>
            </Connection>
          </PushButton>
          <PushButton>
            <ObjectName>BeatLoopPad</ObjectName>
            <Size>0me,48f</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>8</Text></State>
            <State><Number>1</Number><Text>8</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],beatloop_8_activate</ConfigKey>
            </Connection>
          </PushButton>
          <PushButton>
            <ObjectName>BeatLoopPad</ObjectName>
            <Size>0me,48f</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>16</Text></State>
            <State><Number>1</Number><Text>16</Text></State>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],beatloop_16_activate</ConfigKey>
            </Connection>
          </PushButton>
        </Children>
      </WidgetGroup>

    </Children>
  </WidgetGroup>
</Template>
