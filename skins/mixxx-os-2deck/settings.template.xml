<Template>
  <WidgetGroup>
    <ObjectName>Settings</ObjectName>
    <Layout>vertical</Layout>
    <Children>

      <!-- ===== CONFIG SERVEUR ===== -->
      <WidgetGroup>
        <ObjectName>SettingsSection</ObjectName>
        <Layout>vertical</Layout>
        <Children>
          <WidgetGroup>
            <ObjectName>SettingsSectionHeader</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,30f</Size>
            <Children>
              <Label>
                <ObjectName>SettingsSectionTitle</ObjectName>
                <Text>CONFIG SERVEUR</Text>
              </Label>
              <PushButton>
                <ObjectName>OSServerStatus</ObjectName>
                <Size>110f,22f</Size>
                <NumberStates>2</NumberStates>
                <State><Number>0</Number><Text>● HORS LIGNE</Text></State>
                <State><Number>1</Number><Text>● CONNECTÉ</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_server_online</ConfigKey>
                  <ConnectValueFromWidget>false</ConnectValueFromWidget>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>

          <!-- Latence -->
          <WidgetGroup>
            <ObjectName>SettingsRow</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,40f</Size>
            <Children>
              <Label>
                <ObjectName>SettingsRowLabel</ObjectName>
                <Text>Latence</Text>
                <Size>120f,40f</Size>
              </Label>
              <PushButton>
                <ObjectName>OSConfigCycleButton</ObjectName>
                <Size>0me,32f</Size>
                <NumberStates>6</NumberStates>
                <State><Number>0</Number><Text>1 ms</Text></State>
                <State><Number>1</Number><Text>2 ms</Text></State>
                <State><Number>2</Number><Text>5 ms</Text></State>
                <State><Number>3</Number><Text>10 ms</Text></State>
                <State><Number>4</Number><Text>20 ms</Text></State>
                <State><Number>5</Number><Text>46 ms</Text></State>
                <Connection>
                  <ConfigKey persist="true">[Skin],os_latency_idx</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>

          <!-- Actions -->
          <WidgetGroup>
            <ObjectName>SettingsActionsRow</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,44f</Size>
            <Children>
              <PushButton>
                <ObjectName>OSActionSave</ObjectName>
                <Size>0me,34f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>&#10003; Enregistrer</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_save</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>OSActionReload</ObjectName>
                <Size>0me,34f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>&#8635; Recharger</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_reload</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>OSActionRestart</ObjectName>
                <Size>0me,34f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>&#9211; Redémarrer Mixxx</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_restart</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>
        </Children>
      </WidgetGroup>

      <!-- ===== SEPARATOR ===== -->
      <WidgetGroup>
        <ObjectName>SettingsSeparator</ObjectName>
        <Layout>horizontal</Layout>
        <Size>0me,2f</Size>
        <Children/>
      </WidgetGroup>

      <!-- ===== SORTIES AUDIO ===== -->
      <WidgetGroup>
        <ObjectName>SettingsSection</ObjectName>
        <Layout>vertical</Layout>
        <Children>
          <WidgetGroup>
            <ObjectName>SettingsSectionHeader</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,30f</Size>
            <Children>
              <Label><ObjectName>SettingsSectionTitle</ObjectName><Text>SORTIES AUDIO</Text></Label>
            </Children>
          </WidgetGroup>

          <!-- Master output -->
          <WidgetGroup>
            <ObjectName>SettingsRow</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,40f</Size>
            <Children>
              <Label><ObjectName>SettingsRowLabel</ObjectName><Text>Master</Text><Size>120f,40f</Size></Label>
              <!-- Display: server drives this via CC 0x10 (states 0-6=Sortie1-7, 7=—) -->
              <PushButton>
                <ObjectName>OSConfigCycleDisplay</ObjectName>
                <Size>0me,32f</Size>
                <NumberStates><!-- AUDIO_COUNT --></NumberStates>
<!-- AUDIO_STATES -->
                <Connection>
                  <ConfigKey persist="false">[Skin],os_master_out</ConfigKey>
                  <ConnectValueFromWidget>false</ConnectValueFromWidget>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <!-- Cycle to next output -->
              <PushButton>
                <ObjectName>OSActionNext</ObjectName>
                <Size>44f,32f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>&#9654;</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_master_next</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>

          <!-- Headphone output -->
          <WidgetGroup>
            <ObjectName>SettingsRow</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,40f</Size>
            <Children>
              <Label><ObjectName>SettingsRowLabel</ObjectName><Text>Casque</Text><Size>120f,40f</Size></Label>
              <PushButton>
                <ObjectName>OSConfigCycleDisplay</ObjectName>
                <Size>0me,32f</Size>
                <NumberStates><!-- SCRIPT_COUNT --></NumberStates>
<!-- SCRIPT_STATES -->
                <Connection>
                  <ConfigKey persist="false">[Skin],os_headphone_out</ConfigKey>
                  <ConnectValueFromWidget>false</ConnectValueFromWidget>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>OSActionNext</ObjectName>
                <Size>44f,32f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>&#9654;</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_headphone_next</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>
        </Children>
      </WidgetGroup>

      <!-- ===== SEPARATOR ===== -->
      <WidgetGroup>
        <ObjectName>SettingsSeparator</ObjectName>
        <Layout>horizontal</Layout>
        <Size>0me,2f</Size>
        <Children/>
      </WidgetGroup>

      <!-- ===== CONTRÔLEURS MIDI ===== -->
      <WidgetGroup>
        <ObjectName>SettingsSection</ObjectName>
        <Layout>vertical</Layout>
        <Children>
          <WidgetGroup>
            <ObjectName>SettingsSectionHeader</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,30f</Size>
            <Children>
              <Label><ObjectName>SettingsSectionTitle</ObjectName><Text>CONTRÔLEURS MIDI</Text></Label>
            </Children>
          </WidgetGroup>

          <!-- Slot 0 -->
          <WidgetGroup>
            <ObjectName>SettingsRow</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,40f</Size>
            <Children>
              <Label><ObjectName>SettingsRowLabel</ObjectName><Text>Ctrl 1</Text><Size>60f,40f</Size></Label>
              <!-- State: 0=vide 1=inactif 2=actif -->
              <PushButton>
                <ObjectName>OSMidiSlotState</ObjectName>
                <Size>70f,32f</Size>
                <NumberStates>3</NumberStates>
                <State><Number>0</Number><Text>VIDE</Text></State>
                <State><Number>1</Number><Text>INACTIF</Text></State>
                <State><Number>2</Number><Text>ACTIF</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_0_state</ConfigKey>
                  <ConnectValueFromWidget>false</ConnectValueFromWidget>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <!-- Script display: states 0-6 = Script 1-7, 7 = — -->
              <PushButton>
                <ObjectName>OSConfigCycleDisplay</ObjectName>
                <Size>0me,32f</Size>
                <NumberStates><!-- SCRIPT_COUNT --></NumberStates>
<!-- SCRIPT_STATES -->
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_0_script</ConfigKey>
                  <ConnectValueFromWidget>false</ConnectValueFromWidget>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <!-- Next script -->
              <PushButton>
                <ObjectName>OSActionNext</ObjectName>
                <Size>44f,32f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>&#9654;</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_0_script_next</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <!-- Toggle active -->
              <PushButton>
                <ObjectName>OSActionToggle</ObjectName>
                <Size>54f,32f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>On/Off</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_0_toggle</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>

          <!-- Slot 1 -->
          <WidgetGroup>
            <ObjectName>SettingsRow</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,40f</Size>
            <Children>
              <Label><ObjectName>SettingsRowLabel</ObjectName><Text>Ctrl 2</Text><Size>60f,40f</Size></Label>
              <PushButton>
                <ObjectName>OSMidiSlotState</ObjectName>
                <Size>70f,32f</Size>
                <NumberStates>3</NumberStates>
                <State><Number>0</Number><Text>VIDE</Text></State>
                <State><Number>1</Number><Text>INACTIF</Text></State>
                <State><Number>2</Number><Text>ACTIF</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_1_state</ConfigKey>
                  <ConnectValueFromWidget>false</ConnectValueFromWidget>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>OSConfigCycleDisplay</ObjectName>
                <Size>0me,32f</Size>
                <NumberStates><!-- SCRIPT_COUNT --></NumberStates>
<!-- SCRIPT_STATES -->
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_1_script</ConfigKey>
                  <ConnectValueFromWidget>false</ConnectValueFromWidget>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>OSActionNext</ObjectName>
                <Size>44f,32f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>&#9654;</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_1_script_next</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>OSActionToggle</ObjectName>
                <Size>54f,32f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>On/Off</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_1_toggle</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>

          <!-- Slot 2 -->
          <WidgetGroup>
            <ObjectName>SettingsRow</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,40f</Size>
            <Children>
              <Label><ObjectName>SettingsRowLabel</ObjectName><Text>Ctrl 3</Text><Size>60f,40f</Size></Label>
              <PushButton>
                <ObjectName>OSMidiSlotState</ObjectName>
                <Size>70f,32f</Size>
                <NumberStates>3</NumberStates>
                <State><Number>0</Number><Text>VIDE</Text></State>
                <State><Number>1</Number><Text>INACTIF</Text></State>
                <State><Number>2</Number><Text>ACTIF</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_2_state</ConfigKey>
                  <ConnectValueFromWidget>false</ConnectValueFromWidget>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>OSConfigCycleDisplay</ObjectName>
                <Size>0me,32f</Size>
                <NumberStates><!-- SCRIPT_COUNT --></NumberStates>
<!-- SCRIPT_STATES -->
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_2_script</ConfigKey>
                  <ConnectValueFromWidget>false</ConnectValueFromWidget>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>OSActionNext</ObjectName>
                <Size>44f,32f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>&#9654;</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_2_script_next</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>OSActionToggle</ObjectName>
                <Size>54f,32f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>On/Off</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_2_toggle</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>

          <!-- Slot 3 -->
          <WidgetGroup>
            <ObjectName>SettingsRow</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,40f</Size>
            <Children>
              <Label><ObjectName>SettingsRowLabel</ObjectName><Text>Ctrl 4</Text><Size>60f,40f</Size></Label>
              <PushButton>
                <ObjectName>OSMidiSlotState</ObjectName>
                <Size>70f,32f</Size>
                <NumberStates>3</NumberStates>
                <State><Number>0</Number><Text>VIDE</Text></State>
                <State><Number>1</Number><Text>INACTIF</Text></State>
                <State><Number>2</Number><Text>ACTIF</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_3_state</ConfigKey>
                  <ConnectValueFromWidget>false</ConnectValueFromWidget>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>OSConfigCycleDisplay</ObjectName>
                <Size>0me,32f</Size>
                <NumberStates><!-- SCRIPT_COUNT --></NumberStates>
<!-- SCRIPT_STATES -->
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_3_script</ConfigKey>
                  <ConnectValueFromWidget>false</ConnectValueFromWidget>
                  <ConnectValueToWidget>true</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>OSActionNext</ObjectName>
                <Size>44f,32f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>&#9654;</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_3_script_next</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
              <PushButton>
                <ObjectName>OSActionToggle</ObjectName>
                <Size>54f,32f</Size>
                <NumberStates>1</NumberStates>
                <State><Number>0</Number><Text>On/Off</Text></State>
                <Connection>
                  <ConfigKey persist="false">[Skin],os_midi_3_toggle</ConfigKey>
                  <ConnectValueFromWidget>true</ConnectValueFromWidget>
                  <ConnectValueToWidget>false</ConnectValueToWidget>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>
        </Children>
      </WidgetGroup>

      <!-- ===== SEPARATOR ===== -->
      <WidgetGroup>
        <ObjectName>SettingsSeparator</ObjectName>
        <Layout>horizontal</Layout>
        <Size>0me,2f</Size>
        <Children/>
      </WidgetGroup>

      <!-- ===== PISTE ACTIVE ===== -->
      <WidgetGroup>
        <ObjectName>SettingsSection</ObjectName>
        <Layout>vertical</Layout>
        <Children>
          <WidgetGroup>
            <ObjectName>SettingsSectionHeader</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,30f</Size>
            <Children>
              <Label>
                <ObjectName>SettingsSectionTitle</ObjectName>
                <Text>PISTE ACTIVE</Text>
              </Label>
            </Children>
          </WidgetGroup>

          <WidgetGroup>
            <ObjectName>SettingsInfoRow</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,22f</Size>
            <Children>
              <Label>
                <ObjectName>SettingsInfoLabel</ObjectName>
                <Text>Coupe le crossfader vers la piste sélectionnée :</Text>
                <Size>0me,22f</Size>
              </Label>
            </Children>
          </WidgetGroup>

          <PushButton>
            <ObjectName>DeckItem0</ObjectName>
            <Size>0me,40f</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>  Piste 1</Text></State>
            <State><Number>1</Number><Text>  &#10003; Piste 1</Text></State>
            <Connection>
              <ConfigKey>[Skin],select_deck_1</ConfigKey>
              <ConnectValueFromWidget>true</ConnectValueFromWidget>
              <ConnectValueToWidget>false</ConnectValueToWidget>
            </Connection>
            <Connection>
              <ConfigKey persist="false">[Skin],deck_active_1</ConfigKey>
              <ConnectValueFromWidget>false</ConnectValueFromWidget>
              <ConnectValueToWidget>true</ConnectValueToWidget>
            </Connection>
          </PushButton>

          <PushButton>
            <ObjectName>DeckItem1</ObjectName>
            <Size>0me,40f</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>  Piste 2</Text></State>
            <State><Number>1</Number><Text>  &#10003; Piste 2</Text></State>
            <Connection>
              <ConfigKey>[Skin],select_deck_2</ConfigKey>
              <ConnectValueFromWidget>true</ConnectValueFromWidget>
              <ConnectValueToWidget>false</ConnectValueToWidget>
            </Connection>
            <Connection>
              <ConfigKey persist="false">[Skin],deck_active_2</ConfigKey>
              <ConnectValueFromWidget>false</ConnectValueFromWidget>
              <ConnectValueToWidget>true</ConnectValueToWidget>
            </Connection>
          </PushButton>

        </Children>
      </WidgetGroup>

    </Children>
  </WidgetGroup>
</Template>
