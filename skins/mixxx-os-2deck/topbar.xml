<Template>
  <WidgetGroup>
    <ObjectName>Topbar</ObjectName>
    <Layout>vertical</Layout>
    <Size>0me,60f</Size>
    <Children>
      <WidgetGroup>
        <ObjectName>TabControls</ObjectName>
        <Layout>horizontal</Layout>
        <SizePolicy>me,me</SizePolicy>
        <Children>
          <!-- This group fills all space except the 150px Perform slot.
               Inside, equal spacers (1me each) truly center Overview+Browse. -->
          <WidgetGroup>
            <ObjectName>TabButtonsCenter</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,0me</Size>
            <Children>
              <WidgetGroup>
                <ObjectName>TabLeftSpacer</ObjectName>
                <Layout>horizontal</Layout>
                <Size>1me,0me</Size>
                <Children/>
              </WidgetGroup>
              <Template src="skin:tab.xml">
                <SetVariable name="tab_name">Overview</SetVariable>
                <SetVariable name="config_key">overview</SetVariable>
              </Template>
              <Template src="skin:tab.xml">
                <SetVariable name="tab_name">Browse</SetVariable>
                <SetVariable name="config_key">library</SetVariable>
              </Template>
              <WidgetGroup>
                <ObjectName>TabRightSpacer</ObjectName>
                <Layout>horizontal</Layout>
                <Size>1me,0me</Size>
                <Children/>
              </WidgetGroup>
            </Children>
          </WidgetGroup>
          <!-- Fixed 150px slot — always holds space, Perform button hides inside -->
          <WidgetGroup>
            <ObjectName>PerformTabSlot</ObjectName>
            <Layout>horizontal</Layout>
            <Size>150f,0me</Size>
            <Children>
              <PushButton>
                <ObjectName>TabButtonPerform</ObjectName>
                <Size>0me,0me</Size>
                <NumberStates>2</NumberStates>
                <State><Number>0</Number><Text>Perform</Text></State>
                <State><Number>1</Number><Text>Perform</Text></State>
                <Connection>
                  <ConfigKey>[Skin],perform_visible</ConfigKey>
                </Connection>
                <Connection>
                  <ConfigKey>[Tab],overview</ConfigKey>
                  <BindProperty>visible</BindProperty>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>
        </Children>
      </WidgetGroup>
    </Children>
  </WidgetGroup>
</Template>
