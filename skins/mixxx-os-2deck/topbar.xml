<Template>
  <WidgetGroup>
    <ObjectName>Topbar</ObjectName>
    <Layout>vertical</Layout>
    <Size>0me,60f</Size>
    <Children>
      <WidgetGroup>
        <ObjectName>TabControls</ObjectName>
        <Layout>horizontal</Layout>
        <SizePolicy>me,me</SizePolicy>
        <Children>
          <Template src="skin:tab.xml">
            <SetVariable name="tab_name">Overview</SetVariable>
            <SetVariable name="config_key">overview</SetVariable>
          </Template>
          <Template src="skin:tab.xml">
            <SetVariable name="tab_name">Browse</SetVariable>
            <SetVariable name="config_key">library</SetVariable>
          </Template>
          <Template src="skin:tab.xml">
            <SetVariable name="tab_name">Sampler</SetVariable>
            <SetVariable name="config_key">samplers</SetVariable>
          </Template>
          <!-- PERFORM sub-toggle: only visible in Overview mode -->
          <PushButton>
            <ObjectName>TabButtonPerform</ObjectName>
            <Size>12me,12me</Size>
            <NumberStates>2</NumberStates>
            <State><Number>0</Number><Text>Perform</Text></State>
            <State><Number>1</Number><Text>Perform</Text></State>
            <Connection>
              <ConfigKey>[Skin],perform_visible</ConfigKey>
            </Connection>
            <Connection>
              <ConfigKey>[Tab],overview</ConfigKey>
              <BindProperty>visible</BindProperty>
            </Connection>
          </PushButton>
          <PushButton>
            <ObjectName>TabButtonConfig</ObjectName>
            <Size>12me,12me</Size>
            <NumberStates>1</NumberStates>
            <State>
              <Number>0</Number>
              <Text>Config</Text>
            </State>
            <Connection>
              <ConfigKey>[Controls],open_preferences</ConfigKey>
              <ConnectValueFromWidget>true</ConnectValueFromWidget>
              <ConnectValueToWidget>false</ConnectValueToWidget>
            </Connection>
          </PushButton>
        </Children>
      </WidgetGroup>
    </Children>
  </WidgetGroup>
</Template>
