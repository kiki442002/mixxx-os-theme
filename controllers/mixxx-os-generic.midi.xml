<?xml version='1.0' encoding='utf-8'?>
<!--
  Mixxx OS Generic Controller Mapping
  Supports (same MIDI notes per family):
    Preset 0 – Pioneer DDJ-400 / FLX4 / DDJ-200
    Preset 1 – Hercules Inpulse 300 / 500
    Preset 2 – Numark Mixtrack Platinum FX

  Usage:
    1. Load this mapping in Preferences > Controllers for your device.
    2. Select your controller preset in the Skin "Config" tab.

  Conflict notes handled by script:
    0x97/0x00-0x03 : Pioneer deck1 hotcue (P0) vs Hercules deck2 hotcue (P1)
    0x91/0x05      : Hercules deck1 sync (P1) vs Numark deck2 cue (P2)
    0x91/0x06      : Hercules deck1 cue (P1) vs Numark deck2 jog touch (P2)
-->
<MixxxControllerPreset schemaVersion="1" mixxxVersion="2.3">
  <info>
    <name>Mixxx OS Generic</name>
    <author>mixxx-os-theme</author>
    <description>Generic 2-deck mapping for Pioneer DDJ-400/FLX4/DDJ-200, Hercules Inpulse 300/500, Numark Mixtrack Platinum FX. Select preset in the skin Config tab.</description>
  </info>
  <controller id="mixxx-os-generic">
    <scriptfiles>
      <file functionprefix="MixxxOSGeneric" filename="mixxx-os-generic-script.js"/>
      <file filename="mixxx-os-pioneer-script.js"/>
      <file filename="mixxx-os-hercules-script.js"/>
      <file filename="mixxx-os-numark-script.js"/>
    </scriptfiles>
    <controls>

      <!-- ============================================================ -->
      <!-- PIONEER DDJ-400 / FLX4 / DDJ-200 – DECK 1                   -->
      <!-- ============================================================ -->
      <control>
        <group>[Channel1]</group>
        <key>play</key>
        <description>Pioneer Deck1 – Play/Pause</description>
        <status>0x90</status><midino>0x0B</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>cue_default</key>
        <description>Pioneer Deck1 – Cue</description>
        <status>0x90</status><midino>0x0C</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>loop_in</key>
        <description>Pioneer Deck1 – Loop In</description>
        <status>0x90</status><midino>0x10</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>loop_out</key>
        <description>Pioneer Deck1 – Loop Out</description>
        <status>0x90</status><midino>0x11</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.shiftPressed</key>
        <description>Pioneer Deck1 – Shift</description>
        <status>0x90</status><midino>0x3F</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.syncPressed</key>
        <description>Pioneer Deck1 – Sync (Shift+Sync = Master)</description>
        <status>0x90</status><midino>0x58</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.jogTouch</key>
        <description>Pioneer Deck1 – Jog Touch</description>
        <status>0x90</status><midino>0x36</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.jogTurn</key>
        <description>Pioneer Deck1 – Jog Bend</description>
        <status>0xB0</status><midino>0x21</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.jogTurn</key>
        <description>Pioneer Deck1 – Jog Scratch</description>
        <status>0xB0</status><midino>0x22</midino>
        <options><script-binding/></options>
      </control>

      <!-- Pioneer Deck1 hotcues: conflict with Hercules Deck2 – dispatched by script -->
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.hotcueDispatch</key>
        <description>Pioneer Deck1 HC1 / Hercules Deck2 HC1 (dispatch by preset)</description>
        <status>0x97</status><midino>0x00</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.hotcueDispatch</key>
        <description>Pioneer Deck1 HC2 / Hercules Deck2 HC2 (dispatch by preset)</description>
        <status>0x97</status><midino>0x01</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.hotcueDispatch</key>
        <description>Pioneer Deck1 HC3 / Hercules Deck2 HC3 (dispatch by preset)</description>
        <status>0x97</status><midino>0x02</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.hotcueDispatch</key>
        <description>Pioneer Deck1 HC4 / Hercules Deck2 HC4 (dispatch by preset)</description>
        <status>0x97</status><midino>0x03</midino>
        <options><script-binding/></options>
      </control>

      <!-- ============================================================ -->
      <!-- PIONEER DDJ-400 / FLX4 / DDJ-200 – DECK 2                   -->
      <!-- ============================================================ -->
      <control>
        <group>[Channel2]</group>
        <key>play</key>
        <description>Pioneer Deck2 – Play/Pause</description>
        <status>0x91</status><midino>0x0B</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>cue_default</key>
        <description>Pioneer Deck2 – Cue</description>
        <status>0x91</status><midino>0x0C</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>loop_in</key>
        <description>Pioneer Deck2 – Loop In</description>
        <status>0x91</status><midino>0x10</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>loop_out</key>
        <description>Pioneer Deck2 – Loop Out</description>
        <status>0x91</status><midino>0x11</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>MixxxOSGeneric.shiftPressed</key>
        <description>Pioneer Deck2 – Shift</description>
        <status>0x91</status><midino>0x3F</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>MixxxOSGeneric.syncPressed</key>
        <description>Pioneer Deck2 – Sync (Shift+Sync = Master)</description>
        <status>0x91</status><midino>0x58</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>MixxxOSGeneric.jogTouch</key>
        <description>Pioneer Deck2 – Jog Touch</description>
        <status>0x91</status><midino>0x36</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>MixxxOSGeneric.jogTurn</key>
        <description>Pioneer Deck2 – Jog Bend</description>
        <status>0xB1</status><midino>0x21</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>MixxxOSGeneric.jogTurn</key>
        <description>Pioneer Deck2 – Jog Scratch</description>
        <status>0xB1</status><midino>0x22</midino>
        <options><script-binding/></options>
      </control>
      <!-- Pioneer Deck2 hotcues (unique – no conflict) -->
      <control>
        <group>[Channel2]</group>
        <key>hotcue_1_activate</key>
        <description>Pioneer Deck2 – Hotcue 1</description>
        <status>0x99</status><midino>0x00</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>hotcue_2_activate</key>
        <description>Pioneer Deck2 – Hotcue 2</description>
        <status>0x99</status><midino>0x01</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>hotcue_3_activate</key>
        <description>Pioneer Deck2 – Hotcue 3</description>
        <status>0x99</status><midino>0x02</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>hotcue_4_activate</key>
        <description>Pioneer Deck2 – Hotcue 4</description>
        <status>0x99</status><midino>0x03</midino>
        <options><normal/></options>
      </control>

      <!-- Pioneer load buttons -->
      <control>
        <group>[Channel1]</group>
        <key>LoadSelectedTrack</key>
        <description>Pioneer Deck1 – Load</description>
        <status>0x96</status><midino>0x46</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>LoadSelectedTrack</key>
        <description>Pioneer Deck2 – Load</description>
        <status>0x96</status><midino>0x47</midino>
        <options><normal/></options>
      </control>

      <!-- Pioneer browse encoder -->
      <control>
        <group>[Library]</group>
        <key>MoveVertical</key>
        <description>Pioneer – Browse Encoder</description>
        <status>0xB6</status><midino>0x40</midino>
        <options><selectknob/></options>
      </control>

      <!-- ============================================================ -->
      <!-- HERCULES INPULSE 300 / 500 – DECK 1                         -->
      <!-- ============================================================ -->
      <control>
        <group>[Channel1]</group>
        <key>play</key>
        <description>Hercules Deck1 – Play/Pause</description>
        <status>0x91</status><midino>0x07</midino>
        <options><normal/></options>
      </control>
      <!-- 0x91/0x06: conflict Hercules Deck1 cue vs Numark Deck2 jog touch -->
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.cueTouchDispatch</key>
        <description>Hercules Deck1 Cue / Numark Deck2 Jog Touch (dispatch by preset)</description>
        <status>0x91</status><midino>0x06</midino>
        <options><script-binding/></options>
      </control>
      <!-- 0x91/0x05: conflict Hercules Deck1 sync vs Numark Deck2 cue -->
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.syncCueDispatch</key>
        <description>Hercules Deck1 Sync / Numark Deck2 Cue (dispatch by preset)</description>
        <status>0x91</status><midino>0x05</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>LoadSelectedTrack</key>
        <description>Hercules Deck1 – Load</description>
        <status>0x91</status><midino>0x0D</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.jogTouch</key>
        <description>Hercules Deck1 – Jog Touch</description>
        <status>0x91</status><midino>0x08</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.jogTurn</key>
        <description>Hercules Deck1 – Jog Scratch</description>
        <status>0xB1</status><midino>0x09</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.jogTurn</key>
        <description>Hercules Deck1 – Jog Bend</description>
        <status>0xB1</status><midino>0x0A</midino>
        <options><script-binding/></options>
      </control>
      <!-- Hercules Deck1 hotcues (unique – no conflict) -->
      <control>
        <group>[Channel1]</group>
        <key>hotcue_1_activate</key>
        <description>Hercules Deck1 – Hotcue 1</description>
        <status>0x96</status><midino>0x00</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>hotcue_2_activate</key>
        <description>Hercules Deck1 – Hotcue 2</description>
        <status>0x96</status><midino>0x01</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>hotcue_3_activate</key>
        <description>Hercules Deck1 – Hotcue 3</description>
        <status>0x96</status><midino>0x02</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>hotcue_4_activate</key>
        <description>Hercules Deck1 – Hotcue 4</description>
        <status>0x96</status><midino>0x03</midino>
        <options><normal/></options>
      </control>

      <!-- ============================================================ -->
      <!-- HERCULES INPULSE 300 / 500 – DECK 2                         -->
      <!-- ============================================================ -->
      <control>
        <group>[Channel2]</group>
        <key>play</key>
        <description>Hercules Deck2 – Play/Pause</description>
        <status>0x92</status><midino>0x07</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>cue_default</key>
        <description>Hercules Deck2 – Cue</description>
        <status>0x92</status><midino>0x06</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>sync_enabled</key>
        <description>Hercules Deck2 – Sync</description>
        <status>0x92</status><midino>0x05</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>LoadSelectedTrack</key>
        <description>Hercules Deck2 – Load</description>
        <status>0x92</status><midino>0x0D</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>MixxxOSGeneric.jogTouch</key>
        <description>Hercules Deck2 – Jog Touch</description>
        <status>0x92</status><midino>0x08</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>MixxxOSGeneric.jogTurn</key>
        <description>Hercules Deck2 – Jog Scratch</description>
        <status>0xB2</status><midino>0x09</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>MixxxOSGeneric.jogTurn</key>
        <description>Hercules Deck2 – Jog Bend</description>
        <status>0xB2</status><midino>0x0A</midino>
        <options><script-binding/></options>
      </control>

      <!-- Hercules browse encoder -->
      <control>
        <group>[Library]</group>
        <key>MoveVertical</key>
        <description>Hercules – Browse Encoder</description>
        <status>0xB0</status><midino>0x01</midino>
        <options><selectknob/></options>
      </control>

      <!-- ============================================================ -->
      <!-- NUMARK MIXTRACK PLATINUM FX – DECK 1                        -->
      <!-- ============================================================ -->
      <control>
        <group>[Channel1]</group>
        <key>play</key>
        <description>Numark Deck1 – Play/Pause</description>
        <status>0x90</status><midino>0x00</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>cue_default</key>
        <description>Numark Deck1 – Cue</description>
        <status>0x90</status><midino>0x01</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>sync_enabled</key>
        <description>Numark Deck1 – Sync</description>
        <status>0x90</status><midino>0x02</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>LoadSelectedTrack</key>
        <description>Numark Deck1 – Load</description>
        <status>0x9F</status><midino>0x02</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.jogTouch</key>
        <description>Numark Deck1 – Jog Touch</description>
        <status>0x90</status><midino>0x06</midino>
        <options><script-binding/></options>
      </control>
      <control>
        <group>[Channel1]</group>
        <key>MixxxOSGeneric.jogTurn</key>
        <description>Numark Deck1 – Jog Turn</description>
        <status>0xB0</status><midino>0x06</midino>
        <options><script-binding/></options>
      </control>

      <!-- ============================================================ -->
      <!-- NUMARK MIXTRACK PLATINUM FX – DECK 2                        -->
      <!-- ============================================================ -->
      <control>
        <group>[Channel2]</group>
        <key>play</key>
        <description>Numark Deck2 – Play/Pause</description>
        <status>0x91</status><midino>0x00</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>cue_default</key>
        <description>Numark Deck2 – Cue (alt)</description>
        <status>0x91</status><midino>0x01</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>sync_enabled</key>
        <description>Numark Deck2 – Sync</description>
        <status>0x91</status><midino>0x02</midino>
        <options><normal/></options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>LoadSelectedTrack</key>
        <description>Numark Deck2 – Load</description>
        <status>0x9F</status><midino>0x03</midino>
        <options><normal/></options>
      </control>
      <!-- 0x91/0x06 (Numark Deck2 jog touch) handled by cueTouchDispatch above -->
      <control>
        <group>[Channel2]</group>
        <key>MixxxOSGeneric.jogTurn</key>
        <description>Numark Deck2 – Jog Turn</description>
        <status>0xB1</status><midino>0x06</midino>
        <options><script-binding/></options>
      </control>

      <!-- Numark browse encoder -->
      <control>
        <group>[Library]</group>
        <key>MoveVertical</key>
        <description>Numark – Browse Encoder</description>
        <status>0xBF</status><midino>0x00</midino>
        <options><selectknob/></options>
      </control>

    </controls>
  </controller>
</MixxxControllerPreset>
