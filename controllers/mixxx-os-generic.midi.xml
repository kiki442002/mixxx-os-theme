<!--
  Mixxx OS Generic Controller Mapping
  Supports (same MIDI notes per family):
    Preset 0 – Pioneer DDJ-400 / FLX4 / DDJ-200
    Preset 1 – Hercules Inpulse 300 / 500
    Preset 2 – Numark Mixtrack Platinum FX

  Usage:
    1. Load this mapping in Preferences > Controllers for your device.
    2. Select your controller preset in the Skin "Config" tab.

  Conflict notes handled by script:
    0x97/0x00-0x03 : Pioneer deck1 hotcue (P0) vs Hercules deck2 hotcue (P1)
    0x91/0x05      : Hercules deck1 sync (P1) vs Numark deck2 cue (P2)
    0x91/0x06      : Hercules deck1 cue (P1) vs Numark deck2 jog touch (P2)
-->
<MixxxControllerPreset schemaVersion="1" mixxxVersion="2.3">
  <info>
    <name>Mixxx OS Generic</name>
    <author>mixxx-os-theme</author>
    <description>Generic 2-deck mapping for Pioneer DDJ-400/FLX4/DDJ-200, Hercules Inpulse 300/500, Numark Mixtrack Platinum FX. Select preset in the skin Config tab.</description>
  </info>
  <controller id="mixxx-os-generic">
    <scriptfiles>
      <file functionprefix="MixxxOSGeneric" filename="mixxx-os-generic-script.js"/>
      <file filename="mixxx-os-pioneer-script.js"/>
      <file filename="mixxx-os-hercules-script.js"/>
      <file filename="mixxx-os-numark-script.js"/>
    </scriptfiles>
